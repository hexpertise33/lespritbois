---
import { chiffres } from '../data/site';
---

<section class="atelier" id="atelier">
  <div class="wrap atelier__grid">
    <div class="atelier__intro" data-reveal>
      <p class="eyebrow">L'atelier</p>
      <h2 class="section-title">
        Un artisan qui <em>dessine</em>,<br />fabrique et pose.
      </h2>
      <p class="lede">
        Depuis plus de 10 ans, nous accompagnons particuliers et professionnels
        dans la conception et la réalisation de structures en bois sur mesure.
        Notre équipe ne se contente pas de construire : elle conçoit des lieux de vie.
      </p>
      <p class="atelier__text">
        Une équipe pluridisciplinaire — architecte et bureau d'études, charpentiers
        ossature bois, experts étanchéité et couverture, façadiers bardage — et un
        partenariat d'excellence avec Li-Su des Temps pour l'aluminium. Basés aux
        Billaux près de Libourne, nous intervenons dans un rayon d'environ 2h autour
        de Bordeaux.
      </p>
      <a class="btn btn--ghost" href="/contact">Rencontrer l'atelier</a>
    </div>

    <ul class="atelier__chiffres" data-reveal>
      {chiffres.map((c) => (
        <li class="chiffre">
          <span class="chiffre__val">{c.valeur}<span class="chiffre__unite">{c.unite}</span></span>
          <span class="chiffre__label">{c.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .atelier {
    padding-block: var(--space-2xl);
  }
  .atelier__grid {
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }
  .atelier__intro .section-title {
    margin: 1.1rem 0 1.5rem;
  }
  .atelier__intro .lede {
    margin-bottom: 1.2rem;
  }
  .atelier__text {
    color: var(--texte-doux);
    margin-bottom: 2rem;
  }

  .atelier__chiffres {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--ligne);
    border: 1px solid var(--ligne);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .chiffre {
    background: var(--noir);
    padding: clamp(1.5rem, 3vw, 2.5rem);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    transition: background 0.4s var(--ease);
  }
  .chiffre:hover {
    background: var(--brun-noir);
  }
  .chiffre__val {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    line-height: 1;
    color: var(--ivoire);
  }
  .chiffre__unite {
    color: var(--cuivre);
    font-size: 0.5em;
    margin-left: 0.15em;
  }
  .chiffre__label {
    font-size: var(--text-xs);
    color: var(--texte-doux);
    letter-spacing: 0.02em;
  }

  @media (max-width: 820px) {
    .atelier__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
