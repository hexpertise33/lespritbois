---
import { temoignage } from '../data/site';
---

<section class="temo">
  <span class="temo__mark" aria-hidden="true">”</span>
  <div class="wrap temo__inner" data-reveal>
    <blockquote class="temo__quote">{temoignage.citation}</blockquote>
    <cite class="temo__author">{temoignage.auteur}</cite>
  </div>
</section>

<style>
  .temo {
    position: relative;
    padding-block: var(--space-2xl);
    text-align: center;
    overflow: hidden;
    isolation: isolate;
  }
  .temo__mark {
    position: absolute;
    top: -8%;
    left: 50%;
    transform: translateX(-50%);
    z-index: -1;
    font-family: var(--font-display);
    font-size: clamp(18rem, 40vw, 34rem);
    line-height: 1;
    color: var(--cuivre);
    opacity: 0.06;
    pointer-events: none;
    user-select: none;
  }
  .temo__inner {
    max-width: 46rem;
  }
  .temo__quote {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: var(--text-2xl);
    line-height: 1.28;
    color: var(--ivoire);
    margin-bottom: 2rem;
    text-wrap: balance;
  }
  .temo__author {
    font-family: var(--font-label);
    font-style: normal;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.36em;
    text-transform: uppercase;
    color: var(--cuivre);
  }
</style>
