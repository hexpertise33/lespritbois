---
import { metiers } from '../data/site';

// Rythme bento : chaque métier reçoit une taille de tuile.
const tailles = ['is-large', 'is-small', 'is-small', 'is-large', 'is-wide'];
---

<section class="uni" id="univers">
  <div class="wrap">
    <header class="uni__head" data-reveal>
      <div>
        <p class="eyebrow">Découvrez</p>
        <h2 class="uni__title">Nos Univers</h2>
      </div>
      <p class="uni__note">
        Cinq savoir-faire du bois, du sol au toit. Chaque création est une pièce
        unique, dessinée pour s'harmoniser à votre architecture et magnifier votre
        environnement.
      </p>
    </header>

    <div class="uni__grid">
      {metiers.map((m, i) => (
        <a class={`tile ${tailles[i] ?? 'is-small'}`} href={`/savoir-faire/${m.slug}`} data-reveal>
          <span class="tile__media">
            <img src={m.image} alt={`${m.nom} — L'Esprit Bois`} loading="lazy" width="1200" height="900" />
          </span>
          <span class="tile__scrim" aria-hidden="true"></span>
          <span class="tile__body">
            <span class="tile__cat">{m.categorie}</span>
            <span class="tile__name">{m.nom}</span>
            <span class="tile__rule" aria-hidden="true"></span>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .uni {
    padding-block: var(--space-2xl);
  }
  .uni__head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--ligne);
  }
  .uni__title {
    font-size: var(--text-2xl);
    margin-top: 1rem;
  }
  .uni__note {
    max-width: 24rem;
    color: var(--texte-doux);
    font-size: var(--text-sm);
  }

  /* — Grille bento 12 colonnes — */
  .uni__grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: clamp(0.75rem, 1.4vw, 1.5rem);
  }
  .tile {
    position: relative;
    display: block;
    overflow: hidden;
    min-height: clamp(20rem, 34vw, 34rem);
    background: var(--brun-noir);
    border: 1px solid var(--ligne);
    transition: border-color 0.5s var(--ease);
    isolation: isolate;
  }
  .is-large { grid-column: span 7; }
  .is-small { grid-column: span 5; }
  .is-wide  { grid-column: span 12; min-height: clamp(16rem, 24vw, 24rem); }

  .tile:hover { border-color: var(--ligne-cuivre); }

  .tile__media {
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  .tile__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.94;
    transition: transform 0.9s var(--ease-out), opacity 0.7s var(--ease);
  }
  .tile:hover .tile__media img {
    transform: scale(1.06);
    opacity: 1;
  }
  .tile__scrim {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(to top, var(--noir) 0%, rgba(23, 17, 11, 0.1) 48%, transparent 78%);
  }

  .tile__body {
    position: absolute;
    left: clamp(1.5rem, 2.5vw, 3rem);
    bottom: clamp(1.5rem, 2.5vw, 3rem);
    right: clamp(1.5rem, 2.5vw, 3rem);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .tile__cat {
    font-family: var(--font-label);
    font-size: var(--text-2xs);
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--cuivre);
  }
  .tile__name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--ivoire);
    line-height: 1.1;
  }
  .tile__rule {
    height: 1px;
    width: 0;
    margin-top: 0.4rem;
    background: var(--cuivre);
    transition: width 0.7s var(--ease-out);
  }
  .tile:hover .tile__rule { width: 100%; }

  @media (max-width: 860px) {
    .is-large,
    .is-small,
    .is-wide {
      grid-column: span 12;
      min-height: 20rem;
    }
  }
</style>
