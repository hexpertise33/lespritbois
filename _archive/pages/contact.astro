---
import Base from '../layouts/Base.astro';
import { contact, metiers } from '../data/site';
---

<Base
  title="Contact"
  description="Parlons de votre projet d'espace extérieur en bois. Devis gratuit — L'Esprit Bois, Gironde."
>
  <section class="ct">
    <header class="wrap ct__head" data-reveal>
      <p class="eyebrow">Mise en relation</p>
      <h1 class="ct__title">Parlons de <em>votre projet</em>.</h1>
      <span class="ct__rule" aria-hidden="true"></span>
    </header>

    <div class="wrap ct__grid">
      <!-- Colonne infos -->
      <aside class="ct__aside" data-reveal>
        <dl class="ct__coords">
          <div>
            <dt>Nous appeler</dt>
            <dd><a href={contact.telephoneHref}>{contact.telephone}</a></dd>
          </div>
          <div>
            <dt>Email direct</dt>
            <dd><a href={`mailto:${contact.email}`}>{contact.email}</a></dd>
          </div>
          <div>
            <dt>L'atelier</dt>
            <dd>{contact.adresse}<br />{contact.codePostal} {contact.ville}</dd>
          </div>
          <div>
            <dt>Zone d'intervention</dt>
            <dd>{contact.zone}</dd>
          </div>
          <div>
            <dt>Horaires</dt>
            <dd>{contact.horaires}</dd>
          </div>
        </dl>
        <p class="ct__quote">
          « Chaque ouvrage en bois est une pièce d'orfèvrerie. On prend le temps
          d'écouter votre vision pour la transformer en une réalité durable. »
        </p>
      </aside>

      <!-- Formulaire -->
      <form class="ct__form" data-reveal data-contact-form>
        <div class="field">
          <label for="nom">Nom complet</label>
          <input id="nom" name="nom" type="text" autocomplete="name" required />
        </div>
        <div class="field-row">
          <div class="field">
            <label for="email">Adresse email</label>
            <input id="email" name="email" type="email" autocomplete="email" required />
          </div>
          <div class="field">
            <label for="tel">Téléphone</label>
            <input id="tel" name="tel" type="tel" autocomplete="tel" />
          </div>
        </div>
        <div class="field">
          <label for="projet">Nature du projet</label>
          <select id="projet" name="projet">
            <option value="">Sélectionnez une option…</option>
            {metiers.map((m) => <option value={m.nom}>{m.nom}</option>)}
            <option value="Plusieurs / autre">Plusieurs / autre</option>
          </select>
        </div>
        <div class="field">
          <label for="message">Détails du projet</label>
          <textarea id="message" name="message" rows="5" placeholder="Décrivez votre projet, le lieu, vos envies…" required></textarea>
        </div>
        <button class="btn ct__submit" type="submit">
          Envoyer ma demande
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" />
          </svg>
        </button>
        <p class="ct__note" data-form-note>
          Réponse sous 48h ouvrées. En envoyant, votre logiciel de messagerie
          s'ouvre — un formulaire connecté sera activé à la mise en ligne.
        </p>
      </form>
    </div>
  </section>
</Base>

<script define:vars={{ email: contact.email }}>
  const form = document.querySelector('[data-contact-form]');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const d = new FormData(form);
    const sujet = `Demande de devis — ${d.get('projet') || 'Projet'} (${d.get('nom')})`;
    const corps = [
      `Nom : ${d.get('nom')}`,
      `Email : ${d.get('email')}`,
      `Téléphone : ${d.get('tel') || '—'}`,
      `Projet : ${d.get('projet') || '—'}`,
      '',
      d.get('message'),
    ].join('\n');
    window.location.href = `mailto:${email}?subject=${encodeURIComponent(sujet)}&body=${encodeURIComponent(corps)}`;
  });
</script>

<style>
  .ct {
    padding-block: 9rem var(--space-2xl);
  }
  .ct__head {
    max-width: 60rem;
    margin-bottom: var(--space-xl);
  }
  .ct__title {
    font-size: var(--text-3xl);
    margin: 1rem 0 0;
  }
  .ct__rule {
    display: block;
    width: 6rem;
    height: 2px;
    margin-top: 2rem;
    background: var(--cuivre);
  }

  .ct__grid {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
  }

  /* — Colonne infos — */
  .ct__coords {
    display: grid;
    gap: 1.6rem;
    margin: 0;
  }
  .ct__coords > div {
    padding-bottom: 1.6rem;
    border-bottom: 1px solid var(--ligne);
  }
  .ct__coords dt {
    font-family: var(--font-label);
    font-size: var(--text-2xs);
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--texte-doux);
    margin-bottom: 0.5rem;
  }
  .ct__coords dd {
    margin: 0;
    color: var(--texte);
    font-size: var(--text-lg);
    font-weight: 350;
  }
  .ct__coords a:hover { color: var(--cuivre); }
  .ct__quote {
    margin-top: 2rem;
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-lg);
    line-height: 1.4;
    color: var(--texte-doux);
  }

  /* — Formulaire (conteneur surélevé) — */
  .ct__form {
    display: grid;
    gap: 1.5rem;
    padding: clamp(1.75rem, 3.5vw, 3.5rem);
    background: var(--brun-noir);
    border: 1px solid var(--ligne);
  }
  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .field {
    display: grid;
    gap: 0.55rem;
  }
  .field label {
    font-family: var(--font-label);
    font-size: var(--text-2xs);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--texte-doux);
  }
  .field input,
  .field select,
  .field textarea {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--ivoire);
    background: transparent;
    border: 0;
    border-bottom: 1px solid var(--ligne-forte);
    border-radius: 0;
    padding: 0.7rem 0;
    transition: border-color 0.4s var(--ease);
    width: 100%;
  }
  .field textarea { resize: vertical; }
  .field input::placeholder,
  .field textarea::placeholder { color: var(--texte-faible); }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none;
    border-bottom-color: var(--cuivre);
  }
  .field select {
    appearance: none;
    cursor: pointer;
  }
  .field select option { background: var(--noir); color: var(--ivoire); }
  .ct__submit {
    justify-self: start;
    margin-top: 0.5rem;
  }
  .ct__note {
    font-size: var(--text-xs);
    color: var(--texte-faible);
  }

  @media (max-width: 820px) {
    .ct__grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 440px) {
    .field-row { grid-template-columns: 1fr; }
  }
</style>
