---
import { metiers } from '../data/site';
---

<section class="metiers" id="metiers">
  <div class="wrap">
    <header class="metiers__head" data-reveal>
      <p class="eyebrow">Savoir-faire</p>
      <h2 class="section-title">
        Cinq métiers du bois,<br /><em>un même soin</em> du détail.
      </h2>
      <p class="lede metiers__intro">
        Du sol au toit, de la lame de terrasse au bardage de façade — chaque ouvrage
        est étudié, fabriqué et posé par la même main.
      </p>
    </header>

    <div class="metiers__list">
      {metiers.map((m, i) => (
        <article class={`metier ${i % 2 ? 'metier--flip' : ''}`} data-reveal>
          <a class="metier__media" href={`/savoir-faire/${m.slug}`} aria-label={m.nom}>
            <img src={m.image} alt={`${m.nom} — L'Esprit Bois`} loading="lazy" width="1600" height="1000" />
            <span class="metier__slats" aria-hidden="true"></span>
          </a>
          <div class="metier__body">
            <span class="metier__index">{String(i + 1).padStart(2, '0')} / 05</span>
            <h3 class="metier__name">{m.nom}</h3>
            <p class="metier__accroche">{m.accroche}</p>
            <p class="metier__intro">{m.intro}</p>
            <a class="metier__link" href={`/savoir-faire/${m.slug}`}>
              Découvrir
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" />
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .metiers {
    padding-block: var(--space-2xl);
  }
  .metiers__head {
    max-width: 44rem;
    margin-bottom: var(--space-xl);
  }
  .metiers__head .section-title {
    margin: 1.2rem 0 1.4rem;
  }
  .metiers__intro {
    max-width: 38rem;
  }

  .metiers__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .metier {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    align-items: center;
    gap: clamp(1.5rem, 4vw, 4.5rem);
  }
  .metier--flip .metier__media {
    order: 2;
  }

  /* — Média + cadre trame — */
  .metier__media {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: var(--radius-lg);
    aspect-ratio: 16 / 10;
    background: var(--brun-noir);
  }
  .metier__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.9s var(--ease-out);
  }
  .metier__media:hover img {
    transform: scale(1.05);
  }
  /* lames révélées au survol */
  .metier__slats {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: repeating-linear-gradient(
      to right,
      rgba(11, 11, 12, 0.55) 0 2px,
      transparent 2px 42px
    );
    opacity: 0;
    transition: opacity 0.6s var(--ease);
  }
  .metier__media:hover .metier__slats {
    opacity: 1;
  }
  .metier__media::after {
    content: '';
    position: absolute;
    inset: 0;
    border: 1px solid transparent;
    border-radius: var(--radius-lg);
    transition: border-color 0.5s var(--ease);
  }
  .metier__media:hover::after {
    border-color: var(--ligne-cuivre);
  }

  /* — Corps — */
  .metier__body {
    max-width: 34rem;
  }
  .metier__index {
    font-family: var(--font-label);
    font-size: var(--text-xs);
    letter-spacing: 0.24em;
    color: var(--cuivre);
  }
  .metier__name {
    font-size: var(--text-2xl);
    margin: 0.6rem 0 0.9rem;
  }
  .metier__accroche {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-style: italic;
    color: var(--texte);
    line-height: 1.35;
    margin-bottom: 0.8rem;
  }
  .metier__intro {
    color: var(--texte-doux);
    margin-bottom: 1.6rem;
  }
  .metier__link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-label);
    font-size: var(--text-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ivoire);
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--ligne-cuivre);
    transition: gap 0.4s var(--ease-out), border-color 0.3s var(--ease);
  }
  .metier__link:hover {
    gap: 0.9rem;
    border-color: var(--cuivre);
    color: var(--cuivre-lumiere);
  }

  @media (max-width: 860px) {
    .metier {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .metier--flip .metier__media {
      order: 0;
    }
  }
</style>
