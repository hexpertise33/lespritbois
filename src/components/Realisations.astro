---
import { realisations } from '../data/site';
---

<section class="real" id="realisations">
  <div class="wrap">
    <header class="real__head" data-reveal>
      <div>
        <p class="eyebrow">Réalisations</p>
        <h2 class="section-title">Ce que nous bâtissons.</h2>
      </div>
      <p class="real__note">
        Chaque projet est unique. Voici un aperçu de nos ouvrages —
        <em>vos futures photos prendront place ici.</em>
      </p>
    </header>

    <div class="real__grid">
      {realisations.map((r) => (
        <figure class={`shot shot--${r.format}`} data-reveal>
          <img src={r.image} alt={`${r.titre} — ${r.lieu}`} loading="lazy" width="1600" height="1000" />
          <figcaption class="shot__cap">
            <span class="shot__metier">{r.metier}</span>
            <span class="shot__titre">{r.titre}</span>
            <span class="shot__lieu">{r.lieu}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .real {
    padding-block: var(--space-xl) var(--space-2xl);
  }
  .real__head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }
  .real__head .section-title {
    margin-top: 1rem;
  }
  .real__note {
    max-width: 26rem;
    color: var(--texte-doux);
    font-size: var(--text-sm);
  }
  .real__note em {
    color: var(--cuivre);
    font-style: normal;
  }

  .real__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 15rem;
    gap: clamp(0.75rem, 1.5vw, 1.25rem);
    grid-auto-flow: dense;
  }
  .shot--large { grid-column: span 2; grid-row: span 2; }
  .shot--haut { grid-row: span 2; }
  .shot--standard { grid-column: span 2; }

  .shot {
    position: relative;
    margin: 0;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: var(--brun-noir);
  }
  .shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1s var(--ease-out), filter 0.6s var(--ease);
    filter: saturate(0.9) brightness(0.92);
  }
  .shot:hover img {
    transform: scale(1.06);
    filter: saturate(1.05) brightness(1);
  }
  .shot::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(to top, rgba(11, 11, 12, 0.9) 0%, transparent 55%);
    opacity: 0.65;
    transition: opacity 0.5s var(--ease);
  }
  .shot:hover::before { opacity: 0.95; }

  .shot__cap {
    position: absolute;
    left: 0;
    bottom: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 1.25rem 1.35rem;
    transform: translateY(0.4rem);
    opacity: 0.9;
    transition: transform 0.55s var(--ease-out), opacity 0.4s var(--ease);
  }
  .shot:hover .shot__cap { transform: none; opacity: 1; }
  .shot__metier {
    font-family: var(--font-label);
    font-size: var(--text-2xs);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--cuivre-lumiere);
  }
  .shot__titre {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    line-height: 1.15;
  }
  .shot__lieu {
    font-size: var(--text-xs);
    color: var(--texte-doux);
  }

  @media (max-width: 780px) {
    .real__grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 11rem;
    }
    .shot--large { grid-column: span 2; grid-row: span 2; }
    .shot--haut { grid-column: span 1; grid-row: span 2; }
    .shot--standard { grid-column: span 2; grid-row: span 1; }
  }
</style>
