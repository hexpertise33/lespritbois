---
import { ONGLETS, CONTACT } from '../data/navigation';

export interface Props {
  /** Clé de la page courante, pour souligner l'onglet actif. */
  page?: string;
}
const { page = '' } = Astro.props;

const inactif =
  'font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors whitespace-nowrap';
const actif =
  'font-label-md text-label-md text-primary border-b-2 border-secondary pb-1 whitespace-nowrap';

// Les onglets n'apparaissent qu'à partir de 1280 px : en deçà, lockup (233 px)
// + onglets (636 px) + bouton devis (241 px) dépassent la barre et le bouton
// se retrouve coupé. Sous ce seuil, tout passe par le menu déroulant.
const inactifMobile =
  'block py-3 font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors';
const actifMobile =
  'block py-3 font-label-md text-label-md text-primary border-l-2 border-secondary pl-4 -ml-4';
---

<nav class="fixed top-0 w-full z-50 bg-surface/80 backdrop-blur-xl border-b border-surface-variant">
  <div class="flex justify-between items-center px-6 md:px-16 py-6 max-w-container-max mx-auto">
    <a href="/" class="flex items-center gap-3 shrink-0" aria-label="L'Esprit Bois — accueil">
      <img src="/logo-mark-nav.svg" alt="" aria-hidden="true" width="74" height="32" class="h-8 w-auto" />
      <span class="wordmark text-[18px] whitespace-nowrap">
        <span class="text-primary">L'Esprit</span> <span class="text-secondary font-normal">Bois</span>
      </span>
    </a>

    <div class="hidden xl:flex gap-4 items-center">
      {
        ONGLETS.map((o) =>
          o.cle === page ? (
            <a class={actif} href={o.url} aria-current="page" aria-label={o.titreLong}>
              {o.titre}
            </a>
          ) : (
            <a class={inactif} href={o.url} aria-label={o.titreLong}>
              {o.titre}
            </a>
          )
        )
      }
    </div>

    <a
      class="hidden xl:inline-flex bg-primary text-on-primary px-6 py-3 rounded-xl font-label-md text-label-md hover:bg-secondary hover:text-primary transition-all active:scale-95 shadow-lg whitespace-nowrap shrink-0"
      href="/#quote">Demander un devis gratuit</a
    >

    <button
      id="menu-bouton"
      type="button"
      class="xl:hidden text-primary"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="menu-mobile"
    >
      <span id="menu-icone" class="material-symbols-outlined">menu</span>
    </button>
  </div>

  <!-- Menu déroulant, en dessous de 1280 px -->
  <div id="menu-mobile" class="xl:hidden hidden border-t border-surface-variant bg-surface">
    <div class="max-w-container-max mx-auto px-6 md:px-16 py-6">
      <ul class="divide-y divide-surface-variant">
        {
          ONGLETS.map((o) => (
            <li>
              <a
                class={o.cle === page ? actifMobile : inactifMobile}
                href={o.url}
                {...(o.cle === page ? { 'aria-current': 'page' } : {})}
              >
                {o.titreLong ?? o.titre}
              </a>
            </li>
          ))
        }
        <li>
          <a
            class={page === 'a-propos' ? actifMobile : inactifMobile}
            href="/a-propos"
            {...(page === 'a-propos' ? { 'aria-current': 'page' } : {})}>À propos</a
          >
        </li>
      </ul>

      <div class="mt-6 flex flex-col sm:flex-row gap-3">
        <a
          class="flex-1 text-center bg-primary text-on-primary px-6 py-4 rounded-xl font-label-md text-label-md hover:bg-secondary hover:text-primary transition-all"
          href="/#quote">Demander un devis gratuit</a
        >
        <a
          class="flex-1 text-center border border-primary/20 text-primary px-6 py-4 rounded-xl font-label-md text-label-md hover:bg-surface-container transition-all"
          href={CONTACT.telHref}>{CONTACT.telAffiche}</a
        >
      </div>
    </div>
  </div>
</nav>

<script>
  const barre = document.querySelector('nav');
  const bouton = document.getElementById('menu-bouton');
  const menu = document.getElementById('menu-mobile');
  const icone = document.getElementById('menu-icone');

  if (bouton && menu && icone) {
    const ouvrir = (etat: boolean) => {
      menu.classList.toggle('hidden', !etat);
      bouton.setAttribute('aria-expanded', String(etat));
      bouton.setAttribute('aria-label', etat ? 'Fermer le menu' : 'Ouvrir le menu');
      icone.textContent = etat ? 'close' : 'menu';
    };

    bouton.addEventListener('click', () =>
      ouvrir(bouton.getAttribute('aria-expanded') !== 'true')
    );

    // Échap referme, et rend le focus au bouton.
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && bouton.getAttribute('aria-expanded') === 'true') {
        ouvrir(false);
        bouton.focus();
      }
    });

    // Repasser en desktop avec le menu ouvert laisserait un panneau fantôme.
    window.matchMedia('(min-width: 1280px)').addEventListener('change', (e) => {
      if (e.matches) ouvrir(false);
    });
  }

  // Densification de la barre au scroll.
  if (barre) {
    const conteneur = barre.firstElementChild as HTMLElement | null;
    const majuscule = () => {
      const dense = window.scrollY > 50;
      barre.classList.toggle('bg-surface/95', dense);
      barre.classList.toggle('bg-surface/80', !dense);
      conteneur?.classList.toggle('py-4', dense);
      conteneur?.classList.toggle('py-6', !dense);
    };
    majuscule();
    window.addEventListener('scroll', majuscule, { passive: true });
  }
</script>
