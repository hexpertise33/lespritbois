---
import Site from '../layouts/Site.astro';

const jsonld = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Accueil",
        "item": "https://lespritbois.fr/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "À propos",
        "item": "https://lespritbois.fr/a-propos"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "Qui sommes-nous — L'Esprit Bois",
    "mainEntity": {
      "@type": "GeneralContractor",
      "name": "L'Esprit Bois",
      "description": "Charpentiers et constructeurs bois aux Billaux, près de Libourne. Terrasses, pergolas, carports, bardages, extensions et constructions bois, livrées hors d'eau hors d'air. Entreprise certifiée Qualibat, ouvrages couverts par une garantie décennale.",
      "telephone": "+33557406580",
      "email": "contact@lespritbois.fr",
      "url": "https://lespritbois.fr/",
      "sameAs": ["https://www.facebook.com/Eprisbois33"],
      "hasCredential": {
        "@type": "EducationalOccupationalCredential",
        "credentialCategory": "certification",
        "name": "Qualibat"
      },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "1 Aux Pradasses",
        "postalCode": "33500",
        "addressLocality": "Les Billaux",
        "addressRegion": "Gironde",
        "addressCountry": "FR"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": [
          "Monday",
          "Tuesday",
          "Wednesday",
          "Thursday",
          "Friday"
        ],
        "opens": "08:00",
        "closes": "17:00"
      },
      "areaServed": [
        {
          "@type": "City",
          "name": "Libourne"
        },
        {
          "@type": "AdministrativeArea",
          "name": "Gironde"
        },
        {
          "@type": "AdministrativeArea",
          "name": "Nouvelle-Aquitaine"
        }
      ],
      "knowsAbout": [
        "Ossature bois",
        "Charpente",
        "Pergola bioclimatique",
        "Carport",
        "Bardage",
        "Extension et surélévation",
        "Hors d'eau hors d'air"
      ]
    }
