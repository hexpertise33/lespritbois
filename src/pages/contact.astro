---
import Base from '../layouts/Base.astro';
import { contact, metiers } from '../data/site';
---

<Base
  title="Contact"
  description="Parlons de votre projet d'espace extérieur en bois. Devis gratuit — L'Esprit Bois, Gironde."
>
  <section class="ct">
    <div class="wrap ct__grid">
      <!-- Colonne infos -->
      <aside class="ct__aside" data-reveal>
        <p class="eyebrow">Contact</p>
        <h1 class="ct__title">Parlons de<br /><em>votre projet</em>.</h1>
        <p class="ct__intro">
          Décrivez votre envie en quelques mots. On revient vers vous avec des
          pistes concrètes et, si vous le souhaitez, une visite sur place.
        </p>

        <dl class="ct__coords">
          <div>
            <dt>Téléphone</dt>
            <dd><a href={contact.telephoneHref}>{contact.telephone}</a></dd>
          </div>
          <div>
            <dt>Email</dt>
            <dd><a href={`mailto:${contact.email}`}>{contact.email}</a></dd>
          </div>
          <div>
            <dt>Atelier</dt>
            <dd>{contact.adresse}<br />{contact.codePostal} {contact.ville}</dd>
          </div>
          <div>
            <dt>Zone d'intervention</dt>
            <dd>{contact.zone}</dd>
          </div>
          <div>
            <dt>Horaires</dt>
            <dd>{contact.horaires}</dd>
          </div>
        </dl>
      </aside>

      <!-- Formulaire -->
      <form class="ct__form" data-reveal data-contact-form>
        <div class="field">
          <label for="nom">Nom</label>
          <input id="nom" name="nom" type="text" autocomplete="name" required />
        </div>
        <div class="field-row">
          <div class="field">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" autocomplete="email" required />
          </div>
          <div class="field">
            <label for="tel">Téléphone</label>
            <input id="tel" name="tel" type="tel" autocomplete="tel" />
          </div>
        </div>
        <div class="field">
          <label for="projet">Votre projet</label>
          <select id="projet" name="projet">
            <option value="">Choisir…</option>
            {metiers.map((m) => <option value={m.nom}>{m.nom}</option>)}
            <option value="Plusieurs / autre">Plusieurs / autre</option>
          </select>
        </div>
        <div class="field">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" placeholder="Décrivez votre projet, le lieu, vos envies…" required></textarea>
        </div>
        <button class="btn ct__submit" type="submit">
          Envoyer ma demande
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" />
          </svg>
        </button>
        <p class="ct__note" data-form-note>
          Réponse sous 48h ouvrées. En envoyant, votre logiciel de messagerie s'ouvre —
          un formulaire connecté sera activé à la mise en ligne.
        </p>
      </form>
    </div>
  </section>
</Base>

<script define:vars={{ email: contact.email }}>
  const form = document.querySelector('[data-contact-form]');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const d = new FormData(form);
    const sujet = `Demande de devis — ${d.get('projet') || 'Projet'} (${d.get('nom')})`;
    const corps = [
      `Nom : ${d.get('nom')}`,
      `Email : ${d.get('email')}`,
      `Téléphone : ${d.get('tel') || '—'}`,
      `Projet : ${d.get('projet') || '—'}`,
      '',
      d.get('message'),
    ].join('\n');
    window.location.href = `mailto:${email}?subject=${encodeURIComponent(sujet)}&body=${encodeURIComponent(corps)}`;
  });
</script>

<style>
  .ct {
    padding-block: 9rem var(--space-2xl);
  }
  .ct__grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: clamp(2rem, 6vw, 6rem);
    align-items: start;
  }
  .ct__title {
    font-size: var(--text-3xl);
    margin: 1rem 0 1.4rem;
  }
  .ct__intro {
    color: var(--texte-doux);
    max-width: 26rem;
    margin-bottom: 2.5rem;
  }
  .ct__coords {
    display: grid;
    gap: 1.4rem;
    border-top: 1px solid var(--ligne);
    padding-top: 2rem;
  }
  .ct__coords dt {
    font-family: var(--font-label);
    font-size: var(--text-2xs);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cuivre);
    margin-bottom: 0.35rem;
  }
  .ct__coords dd {
    margin: 0;
    color: var(--texte);
    font-size: var(--text-sm);
  }
  .ct__coords a:hover { color: var(--cuivre-lumiere); }

  /* — Formulaire — */
  .ct__form {
    display: grid;
    gap: 1.3rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    background: var(--brun-noir);
    border: 1px solid var(--ligne);
    border-radius: var(--radius-lg);
  }
  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.3rem;
  }
  .field {
    display: grid;
    gap: 0.5rem;
  }
  .field label {
    font-family: var(--font-label);
    font-size: var(--text-2xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--texte-doux);
  }
  .field input,
  .field select,
  .field textarea {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--ivoire);
    background: var(--noir);
    border: 1px solid var(--ligne);
    border-radius: var(--radius);
    padding: 0.85rem 1rem;
    transition: border-color 0.3s var(--ease), box-shadow 0.3s var(--ease);
    width: 100%;
  }
  .field textarea { resize: vertical; }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--cuivre);
    box-shadow: 0 0 0 3px rgba(198, 124, 61, 0.15);
  }
  .field select { appearance: none; cursor: pointer; }
  .ct__submit {
    justify-self: start;
    margin-top: 0.5rem;
  }
  .ct__note {
    font-size: var(--text-xs);
    color: var(--texte-faible);
  }

  @media (max-width: 820px) {
    .ct__grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 440px) {
    .field-row { grid-template-columns: 1fr; }
  }
</style>
